       fhir:definition [ fhir:v "Motsvarar klasserna Observation och Uppgift i patientjournal i NI 2017.\nKardinalitet: Obligatorisk (1..1)." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
