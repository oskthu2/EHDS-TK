       fhir:short [ fhir:v "NI 2017 (Observation.skala) — den mätskala som värdet är uppmätt på." ] ;
       fhir:definition [ fhir:v "Två huvudtyper: nominalskala (kategorisk) och ordinalskala (rangordnad).\nExempel: AUDIT-skalan (0-40 poäng) eller AB0-blodgruppsystemet.\nCVType-regler (TKB): displayName är 1..1 (obligatorisk om fältet anges).\nKardinalitet: Valfri (0..1)." ] ;
