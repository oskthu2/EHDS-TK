       fhir:short [ fhir:v "Tidpunkt med variabel precision (PartialTimeStampType)." ] ;
       fhir:definition [ fhir:v "Format: YYYY | YYYYMM | YYYYMMDD | YYYYMMDDhh | YYYYMMDDhhmm | YYYYMMDDhhmmss.\nPrecision är explicit i formatet. Se OBS-001 (beslutad mappning i FHIR)." ] ;
