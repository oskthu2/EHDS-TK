       fhir:definition [ fhir:v "- root: Den informationsägande vårdgivarens HSA-id\n- extension: Den inom vårdgivaren unika id-beteckningen för observationen\nKardinalitet: Obligatorisk (1..1)." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
