       fhir:short [ fhir:v "Header enligt RIV-TA standard." ] ;
       fhir:definition [ fhir:v "Se separat dokument med fältregler för header [R10].\nKardinalitet: Obligatorisk (1..1)." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
