       fhir:short [ fhir:v "NI 2017 (Observation.beskrivning) — textuell beskrivning som komplement till value." ] ;
       fhir:definition [ fhir:v "Används som komplement till value i de fall ytterligare textuell beskrivning krävs.\nOBS: Om observationen ENDAST består av fritext ska denna anges i value/st.\nKardinalitet: Valfri (0..1)." ] ;
