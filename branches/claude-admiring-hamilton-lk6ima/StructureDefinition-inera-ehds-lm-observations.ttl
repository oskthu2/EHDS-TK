       fhir:short [ fhir:v "Heltal (RIV-TA: int)." ] ;
       fhir:definition [ fhir:v "Ska ENBART användas för skalvärden (t.ex. poäng på AUDIT-skalan).\nFår INTE användas för fysiskt uppmätta värden (längd, vikt etc.) — använd pq för dessa." ] ;
