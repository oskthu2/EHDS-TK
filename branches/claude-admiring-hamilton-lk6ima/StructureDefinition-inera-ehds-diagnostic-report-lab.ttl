           fhir:v "https://fhir.inera.se/ig/ehds-tk/StructureDefinition/inera-ehds-observation-lab"^^xsd:anyURI ;
           fhir:link <https://fhir.inera.se/ig/ehds-tk/StructureDefinition/inera-ehds-observation-lab>
         ] )
       ] ) ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "DiagnosticReport.conclusion" ] ;
       fhir:path [ fhir:v "DiagnosticReport.conclusion" ] ;
       fhir:short [ fhir:v "Beställningsinformation/fritext (laboratoryOrderOutcome.body.text)" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] )
  ] . # 

