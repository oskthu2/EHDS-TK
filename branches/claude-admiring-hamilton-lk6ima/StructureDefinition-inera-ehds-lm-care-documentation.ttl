       fhir:short [ fhir:v "Åtkomstkontrollheader" ] ;
       fhir:definition [ fhir:v "Information för kontroll av åtkomst enligt PDL. Uppgifterna krävs för\nspärrhantering, åtkomstkontroll samt loggning.\nKardinalitet: Obligatorisk." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
